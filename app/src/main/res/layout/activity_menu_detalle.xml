<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/txtFechaMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fecha del Menú"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:elevation="4dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menú del Día:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/txtPlatoPrincipal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="- Plato Principal"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtSopa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="- Sopa"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtBebida"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="- Bebida"
            android:textSize="16sp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmarAsistencia"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONFIRMAR ASISTENCIA"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/imagenQR"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"/>

</LinearLayout>