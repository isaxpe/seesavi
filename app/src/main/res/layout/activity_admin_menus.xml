<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GESTIÓN DE MENÚS"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"/>

    <!-- Contenedor para Fecha y Botón Buscar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/inputFechaMenu"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:hint="Fecha (Ej: 2026-05-29)"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"/>

        <Button
            android:id="@+id/btnBuscarMenu"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="8dp"
            android:text="BUSCAR"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"/>
    </LinearLayout>

    <EditText
        android:id="@+id/inputPlato"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Plato Principal"
        android:background="@android:drawable/editbox_background"
        android:paddingLeft="12dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/inputSopa"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Sopa o Entrada"
        android:background="@android:drawable/editbox_background"
        android:paddingLeft="12dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/inputBebida"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Bebida"
        android:background="@android:drawable/editbox_background"
        android:paddingLeft="12dp"
        android:layout_marginBottom="24dp"/>

    <Switch
        android:id="@+id/switchHabilitarDia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="El comedor estará ABIERTO este día"
        android:textSize="16sp"
        android:checked="true"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGuardarMenu"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="GUARDAR / ACTUALIZAR MENÚ"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:textStyle="bold"/>
</LinearLayout>