<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GESTIÓN DE ESTUDIANTES"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anexar Nuevo Estudiante"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputAdminNumControl"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Número de Control (Ej: 21150000)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/inputAdminNombre"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nombre Completo"
            android:inputType="textCapWords"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/inputAdminPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Asignar Contraseña"
            android:inputType="textPassword"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnAnexarAlumno"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="REGISTRAR / ANEXAR ALUMNO"
            android:backgroundTint="#4CAF50"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quitar Estudiante del Sistema"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#C62828"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/inputAdminEliminarNumControl"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Número de Control a eliminar"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:paddingLeft="12dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnQuitarAlumno"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="ELIMINAR ALUMNO PERMANENTEMENTE"
            android:backgroundTint="#F44336"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>