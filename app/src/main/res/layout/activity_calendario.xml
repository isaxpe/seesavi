<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnMesAnterior"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:backgroundTint="#DDDDDD"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/txtMesAnio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="center"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"/>

        <Button
            android:id="@+id/btnMesSiguiente"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="&gt;"
            android:backgroundTint="#DDDDDD"
            android:textColor="#000000"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dom" android:textAlignment="center" android:textStyle="bold" android:textColor="#777777"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Lun" android:textAlignment="center" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mar" android:textAlignment="center" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mié" android:textAlignment="center" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jue" android:textAlignment="center" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Vie" android:textAlignment="center" android:textStyle="bold" android:textColor="#000000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sáb" android:textAlignment="center" android:textStyle="bold" android:textColor="#777777"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="#E8E8E8"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#444444"
        android:lineSpacingExtra="4dp"
        android:text="🟢 Disponible   🔴 Inactivo\n🔵 Confirmado   ⚪ No Asistió (Pasado)\n🟠 Asistió (Pasado)"/>

</LinearLayout>